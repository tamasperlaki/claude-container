{
  "env": {
    "ENABLE_TOOL_SEARCH": "true",
    "CAVEMAN_DEFAULT_MODE": "ultra"
  },
  "permissions": {
    "defaultMode": "bypassPermissions"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "model": "opusplan",
  "alwaysThinkingEnabled": true,
  "effortLevel": "high",
  "tui": "default",
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh"
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "notify-send 'Claude has finished'"
          }
        ]
      }
    ]
  },
  "skipDangerousModePermissionPrompt": true,
  "httpHookAllowedEnvVars": ["CORALOGIX_API_KEY"],
  "extraKnownMarketplaces": {
    "meltwater-agents": {
      "source": {
        "source": "github",
        "repo": "meltwater/agents"
      }
    },
    "caveman": {
      "source": {
        "source": "github",
        "repo": "JuliusBrussee/caveman"
      }
    }
  },
  "enabledPlugins": {
    "coralogix-querying@meltwater-agents": true,
    "caveman@caveman": true
  }
}
